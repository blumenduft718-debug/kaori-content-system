# ─────────────────────────────────────────────
# 朝の秘書アシスタント 設定ファイル
# このファイルを .env にコピーして値を入力してください
# cp .env.example .env
# ─────────────────────────────────────────────

# Claude API キー（LINE投稿ネタ自動生成に使用）
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Calendar API
# サービスアカウントのJSONファイルパス
GOOGLE_CREDENTIALS_FILE=credentials.json

# 取得するカレンダーのID（"primary" で自分のメインカレンダー）
GOOGLE_CALENDAR_ID=primary
